# ── LLM Provider ────────────────────────────────────────────────────────────
# Which provider to use when ANSWER_MODE=api.  Options: openai | anthropic

ANSWER_MODE=api
LLM_PROVIDER=openai

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Override only if using a proxy or Azure OpenAI endpoint:
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
#Override only if using a proxy or custom Anthropic endpoint: 
#ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
